NODE_ENV=development

# API + Realtime
MIRROR_API_PORT=8787
MIRROR_PUBLIC_URL=http://localhost:8787
MIRROR_WS_PATH=/ws
MIRROR_CORS_ORIGIN=http://localhost:8080

# FTP Ingestion
MIRROR_FTP_HOST=0.0.0.0
MIRROR_FTP_PORT=2121
MIRROR_FTP_USER=mirror
MIRROR_FTP_PASS=mirror

# Storage
MIRROR_STORAGE_ROOT=./storage
MIRROR_DB_PATH=./storage/mirror-db.json

# Queue / Redis
MIRROR_REDIS_HOST=127.0.0.1
MIRROR_REDIS_PORT=6379
# MIRROR_REDIS_PASSWORD=
MIRROR_QUEUE_NAME=mirror-processing
MIRROR_WORKER_CONCURRENCY=4

# Logging
LOG_LEVEL=info
