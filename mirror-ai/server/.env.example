NODE_ENV=development
LOG_LEVEL=info

# API / WebSocket
MIRROR_AI_HOST=0.0.0.0
MIRROR_AI_API_PORT=8787
MIRROR_AI_WS_PUBLIC_URL=ws://localhost:8787/ws
MIRROR_AI_ALLOWED_ORIGINS=http://localhost:8080

# FTP ingestion
MIRROR_AI_FTP_PORT=2121
MIRROR_AI_FTP_USER=mirror
MIRROR_AI_FTP_PASSWORD=mirrorpass
# Optional public passive URL if running behind NAT
MIRROR_AI_FTP_PASV_URL=127.0.0.1

# Storage and metadata
MIRROR_AI_STORAGE_ROOT=./storage
MIRROR_AI_DATA_FILE=./data/metadata.json

# Queue / worker
MIRROR_AI_REDIS_URL=redis://127.0.0.1:6379
MIRROR_AI_WORKER_CONCURRENCY=2
# true = API server also runs worker, false = run separate worker process
MIRROR_AI_RUN_EMBEDDED_WORKER=true

# Defaults
MIRROR_AI_DEFAULT_PRESET=editorial
MIRROR_AI_DEFAULT_RETOUCH=35
MIRROR_AI_DEFAULT_CATEGORY=portrait
