NODE_ENV=development
PORT=4000
API_BASE=/api
CORS_ORIGIN=http://localhost:5173

FTP_ENABLED=true
FTP_HOST=0.0.0.0
FTP_PORT=2121
FTP_USER=mirror
FTP_PASSWORD=mirror
FTP_ROOT_DIR=/
FTP_PASV_URL=127.0.0.1
FTP_PASV_PORT_START=2222
FTP_PASV_PORT_END=2230

REDIS_URL=redis://127.0.0.1:6379
QUEUE_NAME=mirror-ai-images
WORKER_CONCURRENCY=2

STORAGE_ROOT=./storage
PREVIEW_WIDTH=1600
PREVIEW_JPEG_QUALITY=84
FULL_JPEG_QUALITY=92
LOG_LEVEL=info
